# ERPNext on Railway — required environment variables.
# All values shown here are PLACEHOLDERS. Set real values via Railway's variable editor.

# Site name. Use a fixed slug — site directory will be named after this on the volume.
RFP_DOMAIN_NAME=frontend

# Admin password for the ERPNext "Administrator" user (initial login).
RFP_SITE_ADMIN_PASSWORD=replace-with-a-strong-password

# MariaDB connection — point to a Railway-managed MariaDB service.
RFP_DB_HOST=mariadb.railway.internal
RFP_DB_PORT=3306
RFP_DB_ROOT_PASSWORD=replace-with-mariadb-root-password

# Redis connection URLs — use Railway-managed Redis instances.
# RFP_REDIS_QUEUE_URL and RFP_REDIS_SOCKETIO_URL can share the same Redis service.
RFP_REDIS_CACHE_URL=redis://default:redis-password@rediscache.railway.internal:6379
RFP_REDIS_QUEUE_URL=redis://default:redis-password@redisqueue.railway.internal:6379
RFP_REDIS_SOCKETIO_URL=redis://default:redis-password@redisqueue.railway.internal:6379

# Container port — nginx listens on 80.
PORT=80
